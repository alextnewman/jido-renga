# Run Haiku's jam with the derivative revision present at Jam startup.
# UserBuildConfig is included too late to set HAIKU_REVISION. All other
# environment variables, flags, and targets pass through unchanged.
# A caller-provided HAIKU_REVISION overrides the composed value.

set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

: "${HAIKU_REVISION:=$("$script_dir/haiku-revision")}"
export HAIKU_REVISION

# Haiku does not invalidate this cache when only HAIKU_REVISION changes.
revfile=build/haiku-revision
if [ -f "$revfile" ] && [ "$(cat "$revfile" 2>/dev/null)" != "$HAIKU_REVISION" ]; then
	rm -f "$revfile"
fi

exec jam "$@"
