#!/bin/sh
# haiku-revision — compose the Jidō Renga derivative Haiku revision string.
#
#     <upstream>+jido-renga-<version>
#
# <upstream> is, in order of preference:
#   1. UPSTREAM_REVISION from config/revision.conf (hand-recorded — use this when
#      pinning to a known release/beta, since the GitHub mirror lacks hrev tags).
#   2. `git describe` against the captive's hrev tags, if any exist (transformed
#      the same way Haiku's own determine_haiku_revision does).
#   3. g<short-sha> of the captive haiku HEAD.
#
# The result is a derivative identity: it names the upstream we grafted onto and
# our overlay version. Kept well under SYSTEM_REVISION_LENGTH (128).

set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)
JR_TOP=$(CDPATH= cd -- "$script_dir/.." && pwd -P)
conf="$JR_TOP/config/revision.conf"

UPSTREAM_REVISION=
JIDO_RENGA_VERSION=0.0.0
# shellcheck disable=SC1090
[ -f "$conf" ] && . "$conf"

captive="$JR_TOP/haiku"
upstream="$UPSTREAM_REVISION"

if [ -z "$upstream" ] && [ -d "$captive" ]; then
	# Try hrev tags (transform e.g. "hrev57937-12-gabcdef" -> "hrev57937+12"),
	# matching build/scripts/determine_haiku_revision.
	desc=$(git -C "$captive" describe --dirty --tags --match='hrev*' --abbrev=1 2>/dev/null || true)
	if [ -n "$desc" ]; then
		upstream=$(echo "$desc" | sed 's/-g[0-9a-z]\{1,\}//' | sed 's/-/+/g')
	else
		sha=$(git -C "$captive" rev-parse --short=10 HEAD 2>/dev/null || true)
		[ -n "$sha" ] && upstream="g$sha"
	fi
fi

[ -n "$upstream" ] || upstream="unknown"

printf '%s+jido-renga-%s\n' "$upstream" "$JIDO_RENGA_VERSION"
