# Jam-native out-of-tree graft template. tools/weave substitutes the repository
# path and installs this as <HAIKU_OUTPUT_DIR>/UserBuildConfig.
#
# UserBuildConfig is included before PLATFORM exists, so the overlay walk must
# be deferred until KernelAddon rules are active. HAIKU_REVISION must be set
# earlier still and is therefore exported by tools/jr-jam.

JIDO_RENGA_TOP = @JIDO_RENGA_TOP@ ;

# The default BSP composes a Winky-owned image. Set this to `none` before the
# overlay walk to build the add-ons without applying a BSP image policy.
JIDO_RENGA_BSP ?= winky ;

DeferredSubInclude JIDO_RENGA_TOP overlay ;
