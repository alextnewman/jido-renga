SubDir JIDO_RENGA_TOP overlay ;

# Build-time overlay root, entered through DeferredSubInclude after PLATFORM is
# available. Directory classes match the add-ons' canonical Haiku runtime paths.

JIDO_RENGA_BSP ?= winky ;
JIDO_RENGA_INSTALL_IN_IMAGE ?= 1 ;

# Generate the derivative root-package template from the captive template. The
# strict transformer changes provenance only; package identity and dependencies
# continue to track the selected Haiku revision.
actions JidoRengaPackageInfo
{
	"$(2[1])" "$(2[2])" "$(JIDO_RENGA_PACKAGE_INFO_BSP)" > "$(1)"
}

# A repository index accepts packages from only its declared vendor. The
# derivative root belongs to JidoRenga, not the locally composed Haiku index.
JIDO_RENGA_REPOSITORY_WRAPPER
	= [ FDirName $(JIDO_RENGA_TOP) tools jr-build-haiku-repository ] ;

actions HaikuRepository1
{
	"$(HOST_PYTHON)" "$(JIDO_RENGA_REPOSITORY_WRAPPER)" \
		"$(2[1])" "$(2[2])" "$(1)" "$(2[3-])"
}

local jidoRengaPackageInfoTool
	= <jido-renga-build-tool>jr-package-info ;
SEARCH on $(jidoRengaPackageInfoTool)
	= [ FDirName $(JIDO_RENGA_TOP) tools ] ;

local upstreamHaikuPackageInfo
	= <jido-renga-upstream-package-info>haiku ;
SEARCH on $(upstreamHaikuPackageInfo)
	= [ FDirName $(HAIKU_PACKAGE_INFOS_DIR) generic ] ;

local derivativeHaikuPackageInfo = <package-info-source>haiku ;
MakeLocate $(derivativeHaikuPackageInfo)
	: [ FDirName $(HAIKU_OBJECT_DIR) jido-renga package_infos ] ;
local packageInfoBsp = none ;
if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1 {
	packageInfoBsp = $(JIDO_RENGA_BSP) ;
}
JIDO_RENGA_PACKAGE_INFO_BSP on $(derivativeHaikuPackageInfo)
	= $(packageInfoBsp) ;
Depends $(derivativeHaikuPackageInfo)
	: $(jidoRengaPackageInfoTool) $(upstreamHaikuPackageInfo) ;
JidoRengaPackageInfo $(derivativeHaikuPackageInfo)
	: $(jidoRengaPackageInfoTool) $(upstreamHaikuPackageInfo) ;

JIDO_RENGA_SST_FIRMWARE = <jido-renga-firmware>fw_sst_0f28.bin ;
SEARCH on $(JIDO_RENGA_SST_FIRMWARE)
	= [ FDirName $(JIDO_RENGA_TOP) firmware byt_max98090 ] ;
JIDO_RENGA_SST_FIRMWARE_LICENSE
	= <jido-renga-license>LicenseRef-Intel-SST.txt ;
SEARCH on $(JIDO_RENGA_SST_FIRMWARE_LICENSE)
	= [ FDirName $(JIDO_RENGA_TOP) LICENSES ] ;

# Shared modules precede consumers.
SubInclude JIDO_RENGA_TOP overlay bus_managers i2c ;
SubInclude JIDO_RENGA_TOP overlay bus_managers gpio ;
SubInclude JIDO_RENGA_TOP overlay bus_managers iosf_mbi ;

# Bus drivers (host controllers).
SubInclude JIDO_RENGA_TOP overlay busses mmc sdhci_embedded ;

# Leaf drivers.
SubInclude JIDO_RENGA_TOP overlay drivers audio byt_max98090 ;
SubInclude JIDO_RENGA_TOP overlay drivers graphics intel_valleyview ;
SubInclude JIDO_RENGA_TOP overlay drivers gpio byt_gpio ;
SubInclude JIDO_RENGA_TOP overlay drivers input cros_ec_keyboard ;
SubInclude JIDO_RENGA_TOP overlay drivers input i2c_atmel_mxt ;

# Graphics userspace.
SubInclude JIDO_RENGA_TOP overlay accelerants intel_valleyview ;

# Bring-up diagnostics.
SubInclude JIDO_RENGA_TOP overlay bin intel_valleyview_probe ;

# A BSP declares two things: the overlay add-ons to ship and the exact paths in
# haiku.hpkg that it replaces. Controller ownership is resolved at image time.
JIDO_RENGA_BSP_IMAGE_BUS_MANAGERS = ;
JIDO_RENGA_BSP_IMAGE_I2C_BUS_MANAGER = ;
JIDO_RENGA_BSP_IMAGE_BUSSES_MMC = ;
JIDO_RENGA_BSP_IMAGE_DRIVERS_AUDIO = ;
JIDO_RENGA_BSP_IMAGE_DRIVERS_GRAPHICS = ;
JIDO_RENGA_BSP_IMAGE_DRIVERS_GPIO = ;
JIDO_RENGA_BSP_IMAGE_DRIVERS_INPUT = ;
JIDO_RENGA_BSP_IMAGE_ACCELERANTS = ;
JIDO_RENGA_BSP_IMAGE_BIN = ;
JIDO_RENGA_BSP_BOOT_MODULE_TARGETS = ;
JIDO_RENGA_BSP_OMIT_HAIKU_PACKAGE_FILES = ;
JIDO_RENGA_BSP_OMIT_HAIKU_BOOT_MODULE_TARGETS = ;

if $(JIDO_RENGA_BSP) = winky {
	include [ FDirName $(JIDO_RENGA_TOP) config bsp winky.jam ] ;
} else if $(JIDO_RENGA_BSP) != none {
	Exit "Unknown Jido Renga BSP:" $(JIDO_RENGA_BSP) ;
}

# These adapters apply BSP additions and omissions while Haiku's package recipe
# is parsed. Loose add-on targets remain ordinary builds.
#
# Boot-critical add-ons must live in haiku.hpkg because stage two exposes only
# that package before the kernel mounts the boot volume.
#
# Set JIDO_RENGA_INSTALL_IN_IMAGE = 0 in UserBuildConfig (before the overlay
# walk) to build the add-ons without composing them into haiku.hpkg.
# Haiku's package recipe exposes no stock-driver exclusion hook. These public
# package adapters filter exact BSP-owned paths and boot links.
rule JidoRengaPackageTargets directory : targets
{
	local kept = $(targets) ;

	if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
		&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg {
		kept = ;
		local target ;
		for target in $(targets) {
			local path = [ FDirName $(directory) $(target:BSM) ] ;
			if ! $(path) in $(JIDO_RENGA_BSP_OMIT_HAIKU_PACKAGE_FILES) {
				kept += $(target) ;
			}
		}

		local additions ;
		local directoryPath = [ FDirName $(directory) ] ;
		if $(directoryPath) = add-ons/kernel/bus_managers {
			additions = $(JIDO_RENGA_BSP_IMAGE_BUS_MANAGERS) ;
		} else if $(directoryPath) = add-ons/kernel/busses/mmc {
			additions = $(JIDO_RENGA_BSP_IMAGE_BUSSES_MMC) ;
		} else if $(directoryPath) = add-ons/accelerants {
			additions = $(JIDO_RENGA_BSP_IMAGE_ACCELERANTS) ;
		} else if $(directoryPath) = bin {
			additions = $(JIDO_RENGA_BSP_IMAGE_BIN) ;
		} else if $(directoryPath) = add-ons/kernel/drivers/gpio {
			additions = $(JIDO_RENGA_BSP_IMAGE_DRIVERS_GPIO) ;
		}

		for target in $(additions) {
			if ! $(target) in $(kept) {
				kept += $(target) ;
			}
		}
	}

	return $(kept) ;
}


rule JidoRengaBootModuleTargets targets
{
	local kept = $(targets) ;

	if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
		&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg {
		kept = ;
		local target ;
		for target in $(targets) {
			if ! $(target:BSM) in $(JIDO_RENGA_BSP_OMIT_HAIKU_BOOT_MODULE_TARGETS) {
				kept += $(target) ;
			}
		}

		for target in $(JIDO_RENGA_BSP_BOOT_MODULE_TARGETS) {
			if ! $(target) in $(kept) {
				kept += $(target) ;
			}
		}
	}

	return $(kept) ;
}

rule JidoRengaAddBspPackageFiles
{
	local package = $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) ;
	if $(JIDO_RENGA_INSTALL_IN_IMAGE) != 1
		|| $(JIDO_RENGA_BSP) != winky
		|| $(package) != haiku.hpkg {
		return ;
	}

	local added
		= [ on $(package) return $(JIDO_RENGA_BSP_PACKAGE_FILES_ADDED) ] ;
	if $(added) {
		return ;
	}
	JIDO_RENGA_BSP_PACKAGE_FILES_ADDED on $(package) = 1 ;

	if $(JIDO_RENGA_BSP_IMAGE_DRIVERS_GPIO) {
		AddFilesToContainer $(package) : add-ons kernel drivers gpio
			: $(JIDO_RENGA_BSP_IMAGE_DRIVERS_GPIO) ;
	}
	AddFilesToContainer $(package) : data firmware byt_max98090
		: $(JIDO_RENGA_SST_FIRMWARE) ;
	AddFilesToContainer $(package) : data licenses
		: $(JIDO_RENGA_SST_FIRMWARE_LICENSE) : "Intel (SST firmware)" ;
}


rule AddFilesToPackage directory : targets : destName
{
	if ! [ FDontRebuildCurrentPackage ] {
		JidoRengaAddBspPackageFiles ;
		targets = [ JidoRengaPackageTargets $(directory) : $(targets) ] ;
		AddFilesToContainer $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE)
			: $(directory) : $(targets) : $(destName) ;

		if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
			&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg
			&& [ FDirName $(directory) ] = add-ons/kernel/bus_managers
			&& $(JIDO_RENGA_BSP_IMAGE_I2C_BUS_MANAGER) {
			AddFilesToContainer $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE)
				: $(directory) : $(JIDO_RENGA_BSP_IMAGE_I2C_BUS_MANAGER)
				: i2c ;
		}
	}
}


rule AddBootModuleSymlinksToPackage targets
{
	if ! [ FDontRebuildCurrentPackage ] {
		targets = [ JidoRengaBootModuleTargets $(targets) ] ;
		AddBootModuleSymlinksToContainer $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE)
			: $(targets) ;
	}
}


rule AddDriversToPackage relativeDirectoryTokens : targets
{
	if ! [ FDontRebuildCurrentPackage ] {
		if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
			&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg {
			local kept ;
			local target ;
			for target in $(targets) {
				# BSP paths name the driver class, not Haiku's bin/dev split.
				local path = [ FDirName add-ons kernel drivers
					$(relativeDirectoryTokens[1]) $(target:BSM) ] ;
				if ! $(path) in $(JIDO_RENGA_BSP_OMIT_HAIKU_PACKAGE_FILES) {
					kept += $(target) ;
				}
			}
			targets = $(kept) ;
		}

		AddDriversToContainer $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE)
			: $(relativeDirectoryTokens) : $(targets) ;
	}
}


rule AddNewDriversToPackage relativeDirectoryTokens : targets
{
	if ! [ FDontRebuildCurrentPackage ] {
		if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
			&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg {
			local kept ;
			local target ;
			for target in $(targets) {
				local path = [ FDirName add-ons kernel drivers
					$(relativeDirectoryTokens) $(target:BSM) ] ;
				if ! $(path) in $(JIDO_RENGA_BSP_OMIT_HAIKU_PACKAGE_FILES) {
					kept += $(target) ;
				}
			}
			targets = $(kept) ;
		}

		if $(JIDO_RENGA_INSTALL_IN_IMAGE) = 1
			&& $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE) = haiku.hpkg {
			local additions ;
			if [ FDirName $(relativeDirectoryTokens) ] = audio/hmulti {
				additions = $(JIDO_RENGA_BSP_IMAGE_DRIVERS_AUDIO) ;
			} else if [ FDirName $(relativeDirectoryTokens) ] = graphics {
				additions = $(JIDO_RENGA_BSP_IMAGE_DRIVERS_GRAPHICS) ;
			} else if [ FDirName $(relativeDirectoryTokens) ] = input {
				additions = $(JIDO_RENGA_BSP_IMAGE_DRIVERS_INPUT) ;
			}
			local target ;
			for target in $(additions) {
				if ! $(target) in $(targets) {
					targets += $(target) ;
				}
			}
		}

		AddNewDriversToContainer $(HAIKU_CURRENTLY_BUILT_HAIKU_PACKAGE)
			: $(relativeDirectoryTokens) : $(targets) ;
	}
}


# Build a publishable repository without registering it in composed images.
# The official Haiku and HaikuPorts repositories remain the image defaults.
local imageRepositories = $(HAIKU_REPOSITORIES) ;
local jidoRengaRepository = <repository>JidoRenga ;
MakeLocate $(jidoRengaRepository)
	: $(HAIKU_PACKAGE_REPOSITORIES_DIR_$(HAIKU_PACKAGING_ARCH)) ;

local jidoRengaRepositoryInfo
	= <repository-info-template>jido_renga ;
SEARCH on $(jidoRengaRepositoryInfo)
	= [ FDirName $(JIDO_RENGA_TOP) config repository_infos ] ;

HaikuRepository $(jidoRengaRepository)
	: $(jidoRengaRepositoryInfo) : haiku.hpkg ;
HAIKU_REPOSITORIES = $(imageRepositories) ;

NotFile jido-renga-repository ;
Depends jido-renga-repository : $(jidoRengaRepository) ;
