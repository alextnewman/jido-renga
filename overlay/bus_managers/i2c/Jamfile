SubDir JIDO_RENGA_TOP overlay bus_managers i2c ;

UsePrivateHeaders i2c ;
UsePrivateKernelHeaders ;

# Reuse Haiku's I2C implementation except for I2CBus.cpp, whose device-node
# attribute construction is hardened locally. The captive source remains
# pristine and supplies the module/device plumbing unchanged.
local captiveI2c = [ FDirName $(HAIKU_TOP)
	src add-ons kernel bus_managers i2c ] ;
SubDirHdrs $(captiveI2c) ;
SEARCH_SOURCE += $(captiveI2c) ;

KernelAddon i2c_guarded :
	I2CBus.cpp
	I2CDevice.cpp
	I2CModule.cpp
	bus_raw.cpp
	;
