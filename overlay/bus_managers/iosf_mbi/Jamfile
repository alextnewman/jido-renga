SubDir JIDO_RENGA_TOP overlay bus_managers iosf_mbi ;

# Kernel ABI comes from the captive Haiku submodule.
UsePrivateKernelHeaders ;

# Shared consumers include the module API as <common/iosf_mbi.h>. It must remain
# outside Haiku's private <drivers/...> namespace.
SubDirSysHdrs $(JIDO_RENGA_TOP) overlay headers ;

if $(TARGET_ARCH) = "x86" || $(TARGET_ARCH) = "x86_64" {
	KernelAddon iosf_mbi :
		iosf_mbi.cpp
	;
}
