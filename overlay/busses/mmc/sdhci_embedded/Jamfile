SubDir JIDO_RENGA_TOP overlay busses mmc sdhci_embedded ;

# Kernel C++ has no RTTI.
SubDirC++Flags -fno-rtti ;

SubDirSysHdrs $(HAIKU_TOP) headers os drivers ;
# IOSF-MBI publishes <common/iosf_mbi.h> from the overlay include root.
SubDirSysHdrs $(JIDO_RENGA_TOP) overlay headers ;
SubDirHdrs $(HAIKU_TOP) src add-ons kernel bus_managers acpi acpica include ;
UsePrivateKernelHeaders ;
UsePrivateHeaders drivers ;

# eMMC uses IOSchedulerSimple and DMAResource; removable SD uses IORequest.
SubDirHdrs $(HAIKU_TOP) src system kernel device_manager ;

# The controller stack is one kernel add-on.
if $(TARGET_ARCH) = "x86" || $(TARGET_ARCH) = "x86_64" {
	KernelAddon sdhci_embedded :
		sdhci_embedded.cpp
		BytAcpi.cpp
		SdhciController.cpp
		SdhciEngine.cpp
		AcpiCrs.cpp
		Card.cpp
		SdCard.cpp
		MmcCard.cpp
		Disk.cpp
		Adma2Disk.cpp
		SdmaDisk.cpp
		PioDisk.cpp
		Matcher.cpp
		Personality.cpp
	;
}
